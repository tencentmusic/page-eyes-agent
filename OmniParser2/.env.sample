# 调试用，开启后代码更新会自动重启
AUTO_RELOAD=True

LOG_LEVEL=INFO
# 限流配置
MAX_CONCURRENCY=1

OPENAPI_URL=/openapi.json


# 使用腾讯云COS
COS_SECRET_ID=xxx
COS_SECRET_KEY=xxx
COS_ENDPOINT=xxx
COS_BUCKET=xxx

# OCR 配置
OCR_TEXT_RECOGNITION_BATCH_SIZE=4

# Caption 配置
CAPTION_BATCH_SIZE=16
CAPTION_USE_FT_MODEL=True

MILVUS_HOST=xx.xx.xx.xx
MILVUS_PORT=19530
MILVUS_THRESHOLD=0.9999
MILVUS_ENABLE=True




