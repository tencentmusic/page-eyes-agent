# Agent 模型配置
AGENT_MODEL=openai:deepseek-chat
AGENT_DEBUG=True
AGENT_HEADLESS=False
AGENT_LOG_GRAPH_NODE=True

LOGURU_LEVEL=INFO

BROWSER_HEADLESS=True

# LLM 配置
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=xxx-xxx-xxx-xxx-xxx

# Agent 模型类型, 默认为 llm, 可选为 vlm
AGENT_MODEL_TYPE=llm

# OmniParser 配置, 仅当 AGENT_MODEL_TYPE 为 llm 时需要配置
OMNI_BASE_URL=http://127.0.0.1:8000

# 使用 MinIO, 对象存储，可不配置
MINIO_ACCESS_KEY=xxx
MINIO_SECRET_KEY=xxx
MINIO_ENDPOINT=host:port
MINIO_BUCKET=bucket-name

# 使用腾讯云COS，对象存储，可不配置
#COS_SECRET_ID=xxx
#COS_SECRET_KEY=xxx
#COS_ENDPOINT=xxx
#COS_BUCKET=xxx